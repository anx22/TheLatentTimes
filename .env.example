# Convex deployment (browser-visible — required for the React client)
VITE_CONVEX_URL=https://<your-deployment>.convex.cloud

# Local development only — used by `npx convex dev`
# CONVEX_DEPLOY_KEY=dev:<your-deployment>|<key>

# IMPORTANT: GEMINI_API_KEY is NOT set here anymore.
# It lives only in the Convex deployment environment, so it never reaches
# the browser bundle. Set it once with:
#   npx convex env set GEMINI_API_KEY <your-google-ai-studio-key>
